generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model comments {
  id         String   @id @unique(map: "id") @db.VarChar(10)
  place_id   String   @db.VarChar(10)
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  content    String   @db.VarChar(255)
  places     places   @relation(fields: [place_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comments_ibfk_1")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comments_ibfk_2")

  @@index([place_id], map: "place_id")
  @@index([user_id], map: "user_id")
}

model media_places {
  id       Int    @id @default(autoincrement())
  place_id String @db.VarChar(10)
  url      String @db.Text
  places   places @relation(fields: [place_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "media_places_ibfk_1")

  @@index([place_id], map: "place_id")
}

model places {
  id            String         @id @db.VarChar(10)
  title         String         @db.VarChar(20)
  description   String         @db.VarChar(200)
  type          String         @db.VarChar(12)
  region        String         @db.VarChar(50)
  sigla         String         @db.VarChar(2)
  city          String         @db.VarChar(50)
  max_people    Int
  default_value Float
  owner_id      Int
  lat           String         @unique(map: "lat") @db.VarChar(30)
  lon           String         @unique(map: "lon") @db.VarChar(30)
  available     Boolean        @default(true)
  comments      comments[]
  media_places  media_places[]
  reviews       reviews[]
  services      services[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id         Int      @id @default(autoincrement())
  place_id   String   @db.VarChar(10)
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  rating     Int
  places     places   @relation(fields: [place_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_1")
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "reviews_ibfk_2")

  @@index([place_id], map: "place_id")
  @@index([user_id], map: "user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model services {
  id       Int    @id @default(autoincrement())
  place_id String @db.VarChar(10)
  type     String @db.VarChar(30)
  places   places @relation(fields: [place_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "services_ibfk_1")

  @@unique([place_id, type], map: "place_id")
}


model users {
  id          Int        @id
  given_name  String     @db.VarChar(50)
  family_name String     @db.VarChar(50)
  email       String     @unique(map: "email") @db.VarChar(255)
  icon        String?    @db.VarChar(300)
  birth_date  DateTime   @db.Date
  role        users_role
  comments    comments[]
  reviews     reviews[]
}

enum users_role {
  host
  user
  admin
}
