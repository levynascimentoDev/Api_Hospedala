generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model reviews {
  id                String           @id  @default(uuid())
  accommodationId   String           @db.VarChar(35) @map("accommodation_id")
  authorId          String           @db.VarChar(20) @map("author_id")
  createdAt         DateTime         @default(now()) @map("created_at")
  content           String           @db.Text
  accommodation     accommodations   @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  user              users            @relation(fields: [authorId], references: [id], onDelete: Cascade)
}


model photos {
  accommodationId String          @db.VarChar(35) 
  key             String          @db.VarChar(255)              @id
  cover           Boolean         @default(false)
  accommodation   accommodations  @relation(fields: [accommodationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "media_accommodations_ibfk_1")
}
model accommodations {
  id            String                      @id @db.VarChar(35) @default(cuid())
  ownerId       String                      @db.VarChar(20)                       @map("owner_id")
  available     Boolean                     @default(false)
  currentStep   OnboardingStep              @default(PROPERTY_TYPE)       
  createdAt     DateTime                    @default(now())                       @map("created_at")
  updatedAt     DateTime                    @updatedAt                            @map("updated_at")
  propertyType  property_type?              @map("property_type")
  spacetype     SpaceType?                  @map("space_type")
  title         String?                     @db.MediumText
  description   String?                     @db.Text 
  pricePerNight Decimal?                    @db.Decimal(10, 2)                     @map("price_per_night")
  maxGuests     Int?                        @db.Int @map("max_guests")
  bedrooms      Int?
  bathrooms     Int?
  beds          Int?
  rating        Decimal?                    @db.Decimal(2, 1)          
  reviewCount   Int?
  user          users                       @relation(fields: [ownerId], references: [id])
  reviews       reviews[]
  photos        photos[]
  services      services[]
  address       AddressAccommodation?
}

enum SpaceType {
  ALL
  BEDROOM
  ALBERG
}

enum OnboardingStep {
  PROPERTY_TYPE
  SPACE_TYPE
  SERVICES
  LOCATION
  DETAILS
  PHOTOS
  RULES
  FINISH
  COMPLETED
}

model AddressAccommodation {
  id               Int                         @id                                                    @default(autoincrement())
  lat              Decimal                     @db.Decimal(10, 8)  
  lon              Decimal                     @db.Decimal(11, 8)
  cep              String                      @db.Char(9)
  street           String
  neighborhood     String
  number           Int                        @map("address_number")
  state            String                     @db.Char(2)
  city             String                     @db.VarChar(40)
  accommodationId  String                     @db.VarChar(35)                                           @map("accommodation_id") @unique
  accomodation     accommodations             @relation(fields: [accommodationId], references: [id])
  updatedAt        DateTime                   @updatedAt                                                @map("updated_at")
}

enum property_type {
  APARTAMENTO
  CASA
  POUSADA
  MOTEL
  HOTEL
  RESORT
}

model services {
  id              Int            @id @default(autoincrement())
  accommodationId String         @unique @db.VarChar(35) @map("accommodation_id")

  wifi            Boolean        @default(false)
  air             Boolean        @default(false)
  tv              Boolean        @default(false)
  kitchen         Boolean        @default(false)
  pool            Boolean        @default(false)
  parking         Boolean        @default(false)
  heater          Boolean        @default(false)
  gym             Boolean        @default(false)
  grill           Boolean        @default(false)
  jacuzzi         Boolean        @default(false)
  hotTub          Boolean        @default(false) @map("hot_hub")

  balcony         Boolean        @default(false)
  bedlinen        Boolean        @default(false)
  breakfast       Boolean        @default(false)
  cityView        Boolean        @default(false)
  crib            Boolean        @default(false)
  elevator        Boolean        @default(false)
  reception       Boolean        @default(false)
  safe            Boolean        @default(false)
  seaView         Boolean        @default(false)
  wheelchairAccessibility Boolean @default(false)

  accommodation   accommodations @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
}


model rules {
  id       Int            @id @default(autoincrement())
  animals  Boolean
  events   Boolean
  optional String
  accommodationId  String @db.VarChar(35) @unique
}



model users {
  id             String           @id                   @db.VarChar(20)
  given_name     String           @db.VarChar(50)
  family_name    String           @db.VarChar(50)
  email          String           @unique(map: "email") @db.VarChar(255)
  icon           String?          @db.VarChar(300)
  birth_date     DateTime         @db.Date
  role           users_role
  reviews        reviews[]
  accommodations accommodations[]
}

enum users_role {
  HOST
  USER
  ADMIN
}

